<head>
    <!-- Character encoding for the document -->
    <meta charset="UTF-8">
    
    <!-- Compatibility for older Internet Explorer versions -->
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    
    <!-- Viewport settings for responsive design -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- Page title -->
    <title>Waraqa</title>
    
    <!-- Link to external CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/4.5.2/css/bootstrap.min.css">
    
    <!-- Link to external stylesheet for custom styles -->
    <link rel="stylesheet" href="/css/home-style.css">
    
    <!-- Normalize CSS for better cross-browser rendering -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/normalize/8.0.1/normalize.min.css">
    <!-- Font Awesome for icons -->
    <script src="https://kit.fontawesome.com/eabac940d1.js" crossorigin="anonymous"></script>

    <!-- Dynamic direction for RTL or LTR languages -->
    <script src="/js/setDirection.js"></script>



    <style>
        /* Basic styling for body */
        body {
            padding-top: 0px;
            font-family: 'Arial', sans-serif;
            font-size: 16px;
            direction: ltr; /* Will be overwritten for Arabic dynamically */
        }

        /* Styles for dropdown menus */
        .dropdown {
            position: relative;
            display: inline-block;
        }

        .dropdown-content {
            display: none;
            position: absolute;
            background-color: #f9f9f9;
            min-width: 200px;
            box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.2);
            z-index: 1;
        }

        .dropdown:hover .dropdown-content {
            display: block;
        }

        .dropdown-content .sub-dropdown {
            position: relative;
        }

        .sub-dropdown-content {
            display: none;
            position: absolute;
            left: 100%;
            top: 0;
            background-color: #f9f9f9;
            min-width: 150px;
            box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.2);
            z-index: 1;
        }

        .sub-dropdown:hover .sub-dropdown-content {
            display: block;
        }

        /* Responsive design */
        @media (max-width: 768px) {
            body {
                font-size: 14px;
            }
            .dropdown-content, .sub-dropdown-content {
                min-width: 150px;
            }
        }
    </style>
</head>
